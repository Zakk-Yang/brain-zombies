# ── TEARDOWN ─────────────────────────────────────

cmd_teardown() {
    require_config
    local project
    project="$(project_name)"

    echo ""
    echo "  ${BOLD}Tearing down ${project}...${NC}"

    # Kill dashboard
    if [[ -f "${BZ_DIR}/dashboard.pid" ]]; then
        kill "$(cat "${BZ_DIR}/dashboard.pid")" 2>/dev/null || true
        rm -f "${BZ_DIR}/dashboard.pid"
        ok "Dashboard stopped"
    fi

    # Kill reconcile loop
    if [[ -f "${BZ_DIR}/reconcile.pid" ]]; then
        kill "$(cat "${BZ_DIR}/reconcile.pid")" 2>/dev/null || true
        rm -f "${BZ_DIR}/reconcile.pid"
        ok "Reconcile loop stopped"
    fi

    # Kill tmux sessions AND their child process trees
    tmux list-sessions 2>/dev/null | grep "bz-${project}" | cut -d: -f1 | while read -r sess; do
        # Get all PIDs in the tmux session's panes
        for pane_pid in $(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null); do
            # Kill entire process tree rooted at the pane shell
            # This catches python experiments, training jobs, etc.
            pkill -TERM -P "$pane_pid" 2>/dev/null || true
            # Also kill descendants of descendants (grandchildren)
            for child in $(pgrep -P "$pane_pid" 2>/dev/null); do
                pkill -TERM -P "$child" 2>/dev/null || true
            done
        done
        sleep 1
        # Force-kill any survivors
        for pane_pid in $(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null); do
            pkill -KILL -P "$pane_pid" 2>/dev/null || true
            for child in $(pgrep -P "$pane_pid" 2>/dev/null); do
                pkill -KILL -P "$child" 2>/dev/null || true
            done
        done
        tmux kill-session -t "$sess" 2>/dev/null || true
        ok "Killed session + children: $sess"
    done

    ok "Teardown complete"
    echo ""
}

# ── DASHBOARD ────────────────────────────────────

cmd_dashboard() {
    require_config
    local port="${1:-3333}"
    local url="http://localhost:${port}"
    local dash_pid_file="${BZ_DIR}/dashboard.pid"
    local bz_exec
    bz_exec="$(realpath "${BASH_SOURCE[0]}")"
    local project_root_abs
    project_root_abs="$(pwd -P)"
    local dashboard_session
    dashboard_session="$(session_name "dashboard")"
    local dashboard_log="${BZ_DIR}/logs/dashboard.log"

    mkdir -p "${BZ_DIR}/logs"

    # Kill existing dashboard
    if [[ -f "$dash_pid_file" ]]; then
        kill "$(cat "$dash_pid_file")" 2>/dev/null || true
        rm -f "$dash_pid_file"
    fi
    kill_tmux_session_tree "$dashboard_session"
    lsof -ti:"$port" 2>/dev/null | xargs kill 2>/dev/null || true
    sleep 1

    local cmd
    cmd="cd $(shell_quote "$project_root_abs") && echo \$\$ > $(shell_quote "$dash_pid_file") && exec python3 $(shell_quote "${SCRIPT_DIR}/dashboard/server.py") $(shell_quote "$port") $(shell_quote "$project_root_abs") $(shell_quote "$bz_exec") >> $(shell_quote "$dashboard_log") 2>&1"
    tmux new-session -d -s "$dashboard_session" -x 160 -y 40 "$cmd"
    if wait_dashboard_ready "$url"; then
        ok "Dashboard at ${url} → tmux: ${dashboard_session}"
    else
        warn "Dashboard tmux session started but ${url} did not respond yet. Check ${dashboard_log}."
    fi
    if open_dashboard_url "$url"; then
        ok "Opened dashboard in browser"
    else
        info "Open ${url} in your browser"
    fi
}

# ── CLEAN ────────────────────────────────────────

cmd_clean() {
    require_config
    local project
    project="$(project_name)"

    cmd_teardown

    # Remove worktrees
    if [[ -d "${BZ_DIR}/worktrees" ]]; then
        for wt in "${BZ_DIR}/worktrees"/*/; do
            [[ -d "$wt" ]] || continue
            local branch="bz/$(basename "$wt")"
            git worktree remove "$wt" --force 2>/dev/null || rm -rf "$wt"
            git branch -D "$branch" 2>/dev/null || true
        done
        ok "Removed worktrees"
    fi

    rm -rf "${BZ_DIR}"
    ok "Removed ${BZ_DIR}/"

    echo ""
    info "bz.yaml kept. Run 'bz launch' to restart."
    echo ""
}

# ── FEEDBACK ─────────────────────────────────────

cmd_feedback() {
    local target="${1:-}"
    shift 2>/dev/null || true
    local message="$*"

    require_config

    # Interactive mode if no args
    if [[ -z "$target" ]]; then
        echo ""
        echo "  ${BOLD}📢 bz — Send Feedback${NC}"
        echo ""

        # Show available agents
        echo "  Available zombies:"
        for agent_dir in "${BZ_DIR}/agents"/*/; do
            [[ -d "$agent_dir" ]] || continue
            local aid
            aid="$(basename "$agent_dir")"
            local state
            state="$(grep '^State:' "${agent_dir}/STATUS.md" 2>/dev/null | head -1 | sed 's/State: //')"
            echo "    ${aid} (${state})"
        done
        echo ""

        printf "  Send to which zombie? "
        read -r target
        [[ -z "$target" ]] && { err "No target specified."; exit 1; }

        printf "  Feedback message: "
        read -r message
        [[ -z "$message" ]] && { err "No message."; exit 1; }
    fi

    if [[ -z "$message" ]]; then
        err "Usage: bz feedback <agent> <message>"
        err "   or: bz feedback  (interactive)"
        exit 1
    fi

    control_plane queue-action \
        --from human \
        --to "$target" \
        --kind feedback \
        --summary "$message" \
        --details "$message" \
        --reason "Human feedback" >/dev/null
    control_plane write-state \
        --agent "$target" \
        --phase working \
        --action "addressing human feedback" \
        --summary "Reopened for human feedback." \
        --depends-on human \
        --needs-brain no \
        --files "" \
        --next-step "Read .bz/control/contexts/${target}.md and address the latest action." \
        --blocker none \
        --updated-by human \
        --source feedback >/dev/null
    sync_agent_protocol_to_worktree "$target"

    local sess
    sess="$(session_name "$target")"

    # Check if zombie session exists AND CLI is still running (not just a shell prompt)
    local cli_running=0
    if tmux has-session -t "$sess" 2>/dev/null; then
        # Check if claude/codex process is running in the tmux pane
        local pane_pid
        pane_pid="$(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null | head -1)"
        if [[ -n "$pane_pid" ]] && pgrep -P "$pane_pid" -f "claude|codex|aider" >/dev/null 2>&1; then
            cli_running=1
        fi
    fi

    if [[ "$cli_running" -eq 0 ]]; then
        # Zombie finished — need to restart it with feedback
        warn "Zombie '${target}' CLI not running. Restarting with feedback..."
        for pane_pid in $(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null); do
            pkill -TERM -P "$pane_pid" 2>/dev/null || true
            for child in $(pgrep -P "$pane_pid" 2>/dev/null); do
                pkill -TERM -P "$child" 2>/dev/null || true
            done
        done
        tmux kill-session -t "$sess" 2>/dev/null || true

        local cli_cmd model
        cli_cmd="$(read_yaml_agent_field "$target" "runtime" < /dev/null)"
        model="$(read_yaml_agent_field "$target" "model" < /dev/null)"
        case "$cli_cmd" in
            claude|claude-code) cli_cmd="claude" ;;
            codex) cli_cmd="codex" ;;
        esac

        # Determine work directory
        local work_dir="."
        local wt_path
        wt_path="$(worktree_path "$target")"
        [[ -d "$wt_path" ]] && work_dir="$wt_path"

        local prompt="HUMAN FEEDBACK — act on this immediately:

Read .bz/control/contexts/${target}.md and .bz/control/agents/${target}/latest-action.md first.

Then read your previous work in the worktree and your memory file $(agent_memory_relpath "$target"), apply the fix, commit with [${target}] prefix, update your canonical state with .bz/bin/bzctl write-state, and update your memory with the outcome. Set Needs brain: review when finished."

        tmux new-session -d -s "$sess" -x 200 -y 50
        local cmd
        if [[ "$cli_cmd" == "claude" ]]; then
            cmd="cd $(realpath "$work_dir") && claude --dangerously-skip-permissions"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            cmd="$cmd -p '${prompt}'"
        elif [[ "$cli_cmd" == "codex" ]]; then
            cmd="cd $(shell_quote "$(realpath "$work_dir")") && codex exec --full-auto --add-dir $(shell_quote "$(pwd -P)")"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            cmd="$cmd '${prompt}'"
        else
            cmd="cd $(realpath "$work_dir") && ${cli_cmd} '${prompt}'"
        fi

        tmux send-keys -t "$sess" "$cmd" Enter
        ok "Restarted ${target} with feedback"
    else
        # Zombie still running — send feedback into active session
        tmux send-keys -t "$sess" "NEW HUMAN ACTION queued. Read .bz/control/contexts/${target}.md and .bz/control/agents/${target}/latest-action.md now, then act." Enter
        ok "Sent feedback to ${target}"
    fi

    # Log feedback
    mkdir -p "${BZ_DIR}/logs"
    echo "$(date -Iseconds) | target=${target} | ${message}" >> "${BZ_DIR}/logs/feedback.log"
    if [[ -f "$(agent_memory_relpath "$target")" ]]; then
        {
            echo ""
            echo "## $(date '+%Y-%m-%d %H:%M') — Human feedback"
            echo "- ${message}"
        } >> "$(agent_memory_relpath "$target")"
        sync_agent_protocol_to_worktree "$target"
    fi

    echo ""
    info "Monitor with: bz status"
    echo ""
}

# ── AUTH ─────────────────────────────────────────

cmd_auth() {
    echo ""
    echo "  ${BOLD}🔑 bz — Authentication${NC}"
    echo ""

    local runtimes=("claude" "codex")

    for rt in "${runtimes[@]}"; do
        local cli_name="$rt"
        local status_icon status_text

        if ! command -v "$cli_name" >/dev/null 2>&1; then
            status_icon="${RED}✗${NC}"
            status_text="not installed"
            printf "  ${status_icon} ${BOLD}%-10s${NC} ${status_text}\n" "$cli_name"

            case "$cli_name" in
                claude) echo "    Install: npm install -g @anthropic-ai/claude-code" ;;
                codex)  echo "    Install: npm install -g @openai/codex" ;;
            esac
            continue
        fi

        # Check if authenticated by trying a quick operation
        local authenticated=0
        case "$cli_name" in
            claude)
                if claude --version >/dev/null 2>&1; then
                    # Claude stores auth in ~/.claude/
                    if [[ -d "$HOME/.claude" ]]; then
                        authenticated=1
                    fi
                fi
                ;;
            codex)
                if codex --version >/dev/null 2>&1; then
                    # Codex stores auth in ~/.codex/
                    if [[ -d "$HOME/.codex" ]] && ls "$HOME/.codex/auth"* >/dev/null 2>&1; then
                        authenticated=1
                    else
                        # Check if openai key exists in environment
                        [[ -n "${OPENAI_API_KEY:-}" ]] && authenticated=1
                    fi
                fi
                ;;
        esac

        if [[ "$authenticated" -eq 1 ]]; then
            status_icon="${GREEN}✓${NC}"
            status_text="authenticated"
            printf "  ${status_icon} ${BOLD}%-10s${NC} ${status_text}\n" "$cli_name"
        else
            status_icon="${YELLOW}!${NC}"
            status_text="installed but not authenticated"
            printf "  ${status_icon} ${BOLD}%-10s${NC} ${status_text}\n" "$cli_name"

            printf "    Authenticate now? [Y/n]: "
            read -r answer
            if [[ ! "$answer" =~ ^[Nn] ]]; then
                echo ""
                info "Launching ${cli_name} for authentication..."
                echo "    (Complete the login, then exit with Ctrl-C or type /exit)"
                echo ""
                $cli_name
                echo ""
                ok "${cli_name} authentication complete"
            fi
        fi
    done

    echo ""
}

# Helper: read a field for a specific agent by id
read_yaml_agent_field() {
    local target_id="$1"
    local field="$2"
    python3 -c "
import yaml
with open('bz.yaml') as f:
    data = yaml.safe_load(f)
for a in data.get('agents', []):
    if a.get('id') == '${target_id}':
        print(a.get('${field}', ''))
        break
" 2>/dev/null
}

