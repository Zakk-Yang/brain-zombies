#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BZ_DIR=".bz"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()  { printf "${BLUE}[i]${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}[✓]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[!]${NC} %s\n" "$*"; }
err()   { printf "${RED}[✗]${NC} %s\n" "$*" >&2; }

usage() {
    cat <<EOF
${BOLD}bz${NC} v${VERSION} — Brain for your coding agents

Usage: bz <command> [options]

Commands:
  new              Create a new project from a brief
  auth             Check & setup CLI authentication
  launch           Spawn all agents and supervisor
  status           Show agent states
  feedback         Send human feedback to a zombie
  logs <agent>     Tail agent output
  attach <agent>   Attach to agent tmux session
  teardown         Stop all agents gracefully
  clean            Full purge (kill + delete state)

Options:
  -h, --help       Show this help
  -v, --version    Show version

Examples:
  bz new --brief PROJECT_BRIEF.md
  bz launch
  bz status
  bz attach developer
  bz teardown
EOF
}

# ── Helpers ──────────────────────────────────────

require_config() {
    if [[ ! -f "bz.yaml" ]]; then
        err "No bz.yaml found. Run 'bz new' first."
        exit 1
    fi
}

read_yaml() {
    python3 -c "
import yaml, sys
with open('bz.yaml') as f:
    data = yaml.safe_load(f)
path = sys.argv[1].split('.')
val = data
for p in path:
    if isinstance(val, list):
        val = val[int(p)]
    else:
        val = val.get(p, '')
print(val if val is not None else '')
" "$1" 2>/dev/null
}

read_yaml_list() {
    python3 -c "
import yaml
with open('bz.yaml') as f:
    data = yaml.safe_load(f)
agents = data.get('agents', [])
for a in agents:
    print(a.get('id', ''))
" 2>/dev/null
}

project_name() {
    read_yaml "project.name"
}

session_name() {
    echo "bz-$(project_name)-$1"
}

worktree_path() {
    echo "${BZ_DIR}/worktrees/$1"
}

# ── NEW ──────────────────────────────────────────

cmd_new() {
    local brief_file=""
    local auto_yes=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --brief|-b) brief_file="$2"; shift 2 ;;
            -y) auto_yes=1; shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    if [[ -f "bz.yaml" ]]; then
        warn "bz.yaml already exists. Overwrite? [y/N]"
        read -r answer
        [[ "$answer" =~ ^[Yy] ]] || exit 0
    fi

    echo ""
    echo "  ${BOLD}🧠 bz — New Project${NC}"
    echo ""

    # Read brief
    local brief=""
    if [[ -n "$brief_file" && -f "$brief_file" ]]; then
        brief="$(cat "$brief_file")"
        info "Read brief from $brief_file"
    else
        echo "Paste your project brief (end with Ctrl-D):"
        brief="$(cat)"
    fi

    if [[ -z "$brief" ]]; then
        err "Empty brief. Provide a project description."
        exit 1
    fi

    # Ask runtime preferences
    local runtime="claude"
    local model_tier="balanced"
    local git_strategy="worktree"

    if [[ "$auto_yes" -eq 0 ]]; then
        echo ""
        printf "Coding CLI? [${BOLD}claude${NC} / codex / aider]: "
        read -r answer
        [[ -n "$answer" ]] && runtime="$answer"

        printf "Model tier? [budget / ${BOLD}balanced${NC} / quality]: "
        read -r answer
        [[ -n "$answer" ]] && model_tier="$answer"

        printf "Git strategy? [${BOLD}worktree${NC} / shared]: "
        read -r answer
        [[ -n "$answer" ]] && git_strategy="$answer"
    fi

    # Map runtime to CLI command
    local cli_cmd
    case "$runtime" in
        claude|claude-code) cli_cmd="claude" ;;
        codex) cli_cmd="codex" ;;
        aider) cli_cmd="aider" ;;
        *) cli_cmd="$runtime" ;;
    esac

    # Map model tier to model names
    local supervisor_model agent_model
    case "$cli_cmd" in
        claude)
            case "$model_tier" in
                budget)   supervisor_model="haiku"; agent_model="haiku" ;;
                balanced) supervisor_model="sonnet"; agent_model="sonnet" ;;
                quality)  supervisor_model="opus"; agent_model="opus" ;;
            esac
            ;;
        codex)
            case "$model_tier" in
                budget)   supervisor_model="gpt-4.1-mini"; agent_model="gpt-4.1-mini" ;;
                balanced) supervisor_model="gpt-4.1"; agent_model="gpt-4.1" ;;
                quality)  supervisor_model="gpt-5.4"; agent_model="gpt-5.4" ;;
            esac
            ;;
        *)
            supervisor_model=""; agent_model=""
            ;;
    esac

    info "Generating project config with ${cli_cmd}..."

    # Use the supervisor CLI to analyze the brief and generate config
    source "${SCRIPT_DIR}/lib/planner.sh"
    generate_config "$brief" "$cli_cmd" "$supervisor_model" "$agent_model" "$git_strategy"

    ok "Generated bz.yaml"
    echo ""
    cat bz.yaml
    echo ""

    if [[ "$auto_yes" -eq 0 ]]; then
        printf "Launch now? [Y/n]: "
        read -r answer
        [[ "$answer" =~ ^[Nn] ]] || cmd_launch
    fi
}

# ── LAUNCH ───────────────────────────────────────

cmd_launch() {
    require_config
    local project
    project="$(project_name)"

    echo ""
    echo "  ${BOLD}🚀 bz — Launch${NC}"
    echo "  Project: ${project}"
    echo ""

    mkdir -p "${BZ_DIR}/agents" "${BZ_DIR}/logs"

    # Preflight: check required CLIs are installed and authenticated
    local required_runtimes=()
    local -A checked_runtimes=()
    for _idx in $(python3 -c "
import yaml
with open('bz.yaml') as f:
    d = yaml.safe_load(f)
for i, a in enumerate(d.get('agents', [])):
    print(a.get('runtime', 'claude'))
" < /dev/null 2>/dev/null); do
        required_runtimes+=("$_idx")
    done

    for rt in "${required_runtimes[@]}"; do
        [[ -n "${checked_runtimes[$rt]:-}" ]] && continue
        checked_runtimes[$rt]=1

        local cli_name
        case "$rt" in
            claude|claude-code) cli_name="claude" ;;
            codex) cli_name="codex" ;;
            *) cli_name="$rt" ;;
        esac

        if ! command -v "$cli_name" >/dev/null 2>&1; then
            err "${cli_name} is not installed. Install it first:"
            case "$cli_name" in
                claude) echo "  npm install -g @anthropic-ai/claude-code" ;;
                codex)  echo "  npm install -g @openai/codex" ;;
                *)      echo "  Install ${cli_name} and ensure it's in PATH" ;;
            esac
            exit 1
        fi

        # Quick auth check
        local auth_ok=0
        case "$cli_name" in
            claude)
                if claude --version >/dev/null 2>&1; then auth_ok=1; fi
                ;;
            codex)
                if codex --version >/dev/null 2>&1; then auth_ok=1; fi
                ;;
            *)
                auth_ok=1  # assume ok for unknown CLIs
                ;;
        esac

        if [[ "$auth_ok" -eq 0 ]]; then
            warn "${cli_name} is installed but may not be authenticated."
            printf "  Authenticate now? [Y/n]: "
            read -r auth_answer
            if [[ ! "$auth_answer" =~ ^[Nn] ]]; then
                info "Launching ${cli_name} for authentication..."
                echo "  (Complete the login, then exit with Ctrl-C or type /exit)"
                $cli_name
                ok "${cli_name} authentication complete"
            else
                err "Cannot launch without authentication."
                exit 1
            fi
        fi

        ok "${cli_name} ready"
    done

    # Initialize git if needed
    if [[ ! -d ".git" ]]; then
        git init -q
        git add -A
        git commit -q -m "Initial commit"
        ok "Git initialized"
    fi

    local git_strategy
    git_strategy="$(read_yaml 'git.strategy')"

    # Spawn each agent
    local -a agent_ids=()
    while IFS= read -r _aid; do
        [[ -n "$_aid" ]] && agent_ids+=("$_aid")
    done <<< "$(read_yaml_list)"
    local agent_index=0

    for agent_id in "${agent_ids[@]}"; do

        local runtime cli_cmd model task focus blocked_until
        runtime="$(read_yaml "agents.${agent_index}.runtime" < /dev/null)"
        model="$(read_yaml "agents.${agent_index}.model" < /dev/null)"
        task="$(read_yaml "agents.${agent_index}.task" < /dev/null)"
        focus="$(read_yaml "agents.${agent_index}.focus" < /dev/null)"
        blocked_until="$(read_yaml "agents.${agent_index}.blocked_until" < /dev/null)"

        case "$runtime" in
            claude|claude-code) cli_cmd="claude" ;;
            codex) cli_cmd="codex" ;;
            *) cli_cmd="$runtime" ;;
        esac

        # Create agent dir
        local agent_dir="${BZ_DIR}/agents/${agent_id}"
        mkdir -p "${agent_dir}"

        # Write BRIEF.md
        cat > "${agent_dir}/BRIEF.md" << BRIEFEOF
# Agent: ${agent_id}

## Task
${task}

## Focus directories
${focus}

## Rules
- After EACH file you create/modify: git add <file> && git commit -m "[${agent_id}] <description>"
- Update ${BZ_DIR}/agents/${agent_id}/STATUS.md after each commit
- Set State: done when your task is complete
$([ -n "$blocked_until" ] && echo "- You are BLOCKED until: ${blocked_until}. Set State: blocked until the condition is met.")
BRIEFEOF

        # Write initial STATUS.md
        cat > "${agent_dir}/STATUS.md" << STATUSEOF
# STATUS.md
State: starting
Summary: Not started yet.
Files touched: none
Next step: Read BRIEF.md and begin task.
Blocker: ${blocked_until:-none}
Last updated: $(date '+%Y-%m-%d %H:%M')
STATUSEOF

        # Create worktree if needed
        local work_dir="."
        if [[ "$git_strategy" == "worktree" ]]; then
            local wt_path
            wt_path="$(worktree_path "$agent_id")"
            local branch="bz/${agent_id}"

            if [[ -d "$wt_path" ]]; then
                git worktree remove "$wt_path" --force 2>/dev/null || true
            fi
            git branch -D "$branch" 2>/dev/null || true
            git worktree add -q "$wt_path" -b "$branch" 2>/dev/null || true
            # Copy agent state to worktree
            mkdir -p "${wt_path}/${BZ_DIR}/agents/${agent_id}"
            cp "${agent_dir}/BRIEF.md" "${wt_path}/${BZ_DIR}/agents/${agent_id}/"
            cp "${agent_dir}/STATUS.md" "${wt_path}/${BZ_DIR}/agents/${agent_id}/"
            work_dir="$wt_path"
            ok "Created worktree: ${branch}"
        fi

        # Build agent prompt
        local prompt="You are an autonomous coding agent named '${agent_id}'. Execute your task NOW without asking questions.

Read ${BZ_DIR}/agents/${agent_id}/BRIEF.md for your task.

CRITICAL RULES:
1. After EACH file: git add <file> && git commit -m \"[${agent_id}] <description>\"
2. After each commit: update ${BZ_DIR}/agents/${agent_id}/STATUS.md with current State (working/blocked/done), Summary, Files touched, Next step
3. When fully complete: set State: done in STATUS.md

CONTEXT MANAGEMENT — keep your memory lean:
- Do NOT read files you don't need. Only read files relevant to your current step.
- Do NOT re-read files you already read. Remember what's in them.
- Do NOT cat large files — use grep or head to find what you need.
- Write files in one shot — don't read-modify-write when you can just write.
- Keep STATUS.md updates short — one-line summary, not paragraphs.
- If you receive a brain message, act on it immediately without re-reading everything.

START NOW."

        # Spawn tmux session
        local sess
        sess="$(session_name "$agent_id")"
        tmux kill-session -t "$sess" 2>/dev/null || true

        local cmd
        if [[ "$cli_cmd" == "claude" ]]; then
            cmd="cd $(realpath "$work_dir") && claude --dangerously-skip-permissions"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            cmd="$cmd -p '${prompt}'"
        elif [[ "$cli_cmd" == "codex" ]]; then
            cmd="cd $(realpath "$work_dir") && codex"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            cmd="$cmd --full-auto -q '${prompt}'"
        else
            cmd="cd $(realpath "$work_dir") && ${cli_cmd} '${prompt}'"
        fi

        tmux new-session -d -s "$sess" -x 200 -y 50
        tmux send-keys -t "$sess" "$cmd" Enter
        ok "Spawned ${agent_id} (${cli_cmd}/${model}) → tmux: ${sess}"

        agent_index=$((agent_index + 1))
    done

    # Start reconcile loop
    local reconcile_pid_file="${BZ_DIR}/reconcile.pid"
    if [[ -f "$reconcile_pid_file" ]]; then
        kill "$(cat "$reconcile_pid_file")" 2>/dev/null || true
    fi
    nohup bash "${SCRIPT_DIR}/lib/reconcile.sh" "$(pwd)" > "${BZ_DIR}/logs/reconcile.log" 2>&1 &
    echo $! > "$reconcile_pid_file"
    ok "Reconcile loop started (PID: $!)"

    echo ""
    echo "  ${GREEN}${BOLD}Agents launched!${NC}"
    echo ""
    echo "  ${BOLD}Commands:${NC}"
    echo "    bz status          Show agent states"
    echo "    bz attach <agent>  Attach to agent session"
    echo "    bz logs <agent>    Watch agent output"
    echo "    bz teardown        Stop everything"
    echo ""
}

# ── STATUS ───────────────────────────────────────

cmd_status() {
    require_config
    local project
    project="$(project_name)"

    echo ""
    echo "  ${BOLD}🧠 bz — ${project}${NC}"
    echo ""

    if [[ ! -d "${BZ_DIR}/agents" ]]; then
        warn "No agents found. Run 'bz launch' first."
        return
    fi

    printf "  ${BOLD}%-16s %-10s %-8s %-50s${NC}\n" "Agent" "State" "Ctx" "Summary"
    printf "  %-16s %-10s %-8s %-50s\n" "────────────────" "──────────" "────────" "──────────────────────────────────────────────────"

    for agent_dir in "${BZ_DIR}/agents"/*/; do
        [[ -d "$agent_dir" ]] || continue
        local agent_id
        agent_id="$(basename "$agent_dir")"
        local status_file="${agent_dir}/STATUS.md"

        if [[ ! -f "$status_file" ]]; then
            printf "  %-16s %-10s %-8s %-50s\n" "$agent_id" "unknown" "-" "No STATUS.md"
            continue
        fi

        local state summary ctx_display
        state="$(grep '^State:' "$status_file" 2>/dev/null | head -1 | sed 's/State: //')"
        summary="$(grep '^Summary:' "$status_file" 2>/dev/null | head -1 | sed 's/Summary: //' | cut -c1-48)"

        # Estimate context usage from tmux pane output
        local sess
        sess="$(session_name "$agent_id")"
        ctx_display="-"
        if tmux has-session -t "$sess" 2>/dev/null; then
            local pane_lines
            pane_lines="$(tmux capture-pane -t "$sess" -p -S - 2>/dev/null | wc -c)"
            local est_tokens=$((pane_lines / 4))  # rough: 4 chars ≈ 1 token
            if [[ "$est_tokens" -gt 100000 ]]; then
                ctx_display="${RED}$(( est_tokens / 1000 ))k${NC}"
            elif [[ "$est_tokens" -gt 50000 ]]; then
                ctx_display="${YELLOW}$(( est_tokens / 1000 ))k${NC}"
            else
                ctx_display="${GREEN}$(( est_tokens / 1000 ))k${NC}"
            fi
        fi

        local color="$NC"
        case "$state" in
            done) color="$GREEN" ;;
            working|planning) color="$BLUE" ;;
            blocked) color="$YELLOW" ;;
            *) color="$RED" ;;
        esac

        printf "  %-16s ${color}%-10s${NC} ${ctx_display}%-2s %-50s\n" "$agent_id" "$state" "" "$summary"
    done

    # Show tmux sessions
    echo ""
    local sessions
    sessions="$(tmux list-sessions 2>/dev/null | grep "bz-$(project_name)" || true)"
    if [[ -n "$sessions" ]]; then
        info "Active tmux sessions:"
        echo "$sessions" | while read -r line; do
            echo "    $line"
        done
    fi
    echo ""
}

# ── ATTACH ───────────────────────────────────────

cmd_attach() {
    local agent_id="${1:?Usage: bz attach <agent-id>}"
    require_config
    local sess
    sess="$(session_name "$agent_id")"

    if ! tmux has-session -t "$sess" 2>/dev/null; then
        err "No session found for agent '${agent_id}'"
        echo "Available sessions:"
        tmux list-sessions 2>/dev/null | grep "bz-$(project_name)" || echo "  (none)"
        exit 1
    fi

    info "Attaching to ${agent_id}. Detach with Ctrl-B then D."
    tmux attach-session -t "$sess"
}

# ── LOGS ─────────────────────────────────────────

cmd_logs() {
    local agent_id="${1:?Usage: bz logs <agent-id>}"
    require_config
    local sess
    sess="$(session_name "$agent_id")"

    if ! tmux has-session -t "$sess" 2>/dev/null; then
        err "No session found for agent '${agent_id}'"
        exit 1
    fi

    tmux capture-pane -t "$sess" -p -S -100
}

# ── TEARDOWN ─────────────────────────────────────

cmd_teardown() {
    require_config
    local project
    project="$(project_name)"

    echo ""
    echo "  ${BOLD}Tearing down ${project}...${NC}"

    # Kill reconcile loop
    if [[ -f "${BZ_DIR}/reconcile.pid" ]]; then
        kill "$(cat "${BZ_DIR}/reconcile.pid")" 2>/dev/null || true
        rm -f "${BZ_DIR}/reconcile.pid"
        ok "Reconcile loop stopped"
    fi

    # Kill tmux sessions
    tmux list-sessions 2>/dev/null | grep "bz-${project}" | cut -d: -f1 | while read -r sess; do
        tmux kill-session -t "$sess" 2>/dev/null || true
        ok "Killed session: $sess"
    done

    ok "Teardown complete"
    echo ""
}

# ── CLEAN ────────────────────────────────────────

cmd_clean() {
    require_config
    local project
    project="$(project_name)"

    cmd_teardown

    # Remove worktrees
    if [[ -d "${BZ_DIR}/worktrees" ]]; then
        for wt in "${BZ_DIR}/worktrees"/*/; do
            [[ -d "$wt" ]] || continue
            local branch="bz/$(basename "$wt")"
            git worktree remove "$wt" --force 2>/dev/null || rm -rf "$wt"
            git branch -D "$branch" 2>/dev/null || true
        done
        ok "Removed worktrees"
    fi

    rm -rf "${BZ_DIR}"
    ok "Removed ${BZ_DIR}/"

    echo ""
    info "bz.yaml kept. Run 'bz launch' to restart."
    echo ""
}

# ── FEEDBACK ─────────────────────────────────────

cmd_feedback() {
    local target="${1:-}"
    shift 2>/dev/null || true
    local message="$*"

    require_config

    # Interactive mode if no args
    if [[ -z "$target" ]]; then
        echo ""
        echo "  ${BOLD}📢 bz — Send Feedback${NC}"
        echo ""

        # Show available agents
        echo "  Available zombies:"
        for agent_dir in "${BZ_DIR}/agents"/*/; do
            [[ -d "$agent_dir" ]] || continue
            local aid
            aid="$(basename "$agent_dir")"
            local state
            state="$(grep '^State:' "${agent_dir}/STATUS.md" 2>/dev/null | head -1 | sed 's/State: //')"
            echo "    ${aid} (${state})"
        done
        echo ""

        printf "  Send to which zombie? "
        read -r target
        [[ -z "$target" ]] && { err "No target specified."; exit 1; }

        printf "  Feedback message: "
        read -r message
        [[ -z "$message" ]] && { err "No message."; exit 1; }
    fi

    if [[ -z "$message" ]]; then
        err "Usage: bz feedback <agent> <message>"
        err "   or: bz feedback  (interactive)"
        exit 1
    fi

    local sess
    sess="$(session_name "$target")"

    # Check if zombie session exists AND CLI is still running (not just a shell prompt)
    local cli_running=0
    if tmux has-session -t "$sess" 2>/dev/null; then
        # Check if claude/codex process is running in the tmux pane
        local pane_pid
        pane_pid="$(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null | head -1)"
        if [[ -n "$pane_pid" ]] && pgrep -P "$pane_pid" -f "claude|codex|aider" >/dev/null 2>&1; then
            cli_running=1
        fi
    fi

    if [[ "$cli_running" -eq 0 ]]; then
        # Zombie finished — need to restart it with feedback
        warn "Zombie '${target}' CLI not running. Restarting with feedback..."
        tmux kill-session -t "$sess" 2>/dev/null || true

        local cli_cmd model
        cli_cmd="$(read_yaml_agent_field "$target" "runtime" < /dev/null)"
        model="$(read_yaml_agent_field "$target" "model" < /dev/null)"
        case "$cli_cmd" in
            claude|claude-code) cli_cmd="claude" ;;
            codex) cli_cmd="codex" ;;
        esac

        # Determine work directory
        local work_dir="."
        local wt_path
        wt_path="$(worktree_path "$target")"
        [[ -d "$wt_path" ]] && work_dir="$wt_path"

        # Update STATUS.md to working
        local status_file="${BZ_DIR}/agents/${target}/STATUS.md"
        cat > "$status_file" << STATUSEOF
# STATUS.md
State: working
Summary: Reopened for human feedback.
Files touched: pending
Next step: Address feedback.
Blocker: none
Last updated: $(date '+%Y-%m-%d %H:%M')
STATUSEOF

        local prompt="HUMAN FEEDBACK — act on this immediately:

${message}

Read your previous work in the worktree, apply the fix, commit with [${target}] prefix, and update .bz/agents/${target}/STATUS.md to done when finished."

        tmux new-session -d -s "$sess" -x 200 -y 50
        local cmd
        if [[ "$cli_cmd" == "claude" ]]; then
            cmd="cd $(realpath "$work_dir") && claude --dangerously-skip-permissions"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            cmd="$cmd -p '${prompt}'"
        elif [[ "$cli_cmd" == "codex" ]]; then
            cmd="cd $(realpath "$work_dir") && codex"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            cmd="$cmd --full-auto -q '${prompt}'"
        else
            cmd="cd $(realpath "$work_dir") && ${cli_cmd} '${prompt}'"
        fi

        tmux send-keys -t "$sess" "$cmd" Enter
        ok "Restarted ${target} with feedback"
    else
        # Zombie still running — send feedback into active session
        tmux send-keys -t "$sess" "HUMAN FEEDBACK: ${message}" Enter
        ok "Sent feedback to ${target}"
    fi

    # Log feedback
    mkdir -p "${BZ_DIR}/logs"
    echo "$(date -Iseconds) | target=${target} | ${message}" >> "${BZ_DIR}/logs/feedback.log"

    echo ""
    info "Monitor with: bz status"
    echo ""
}

# ── AUTH ─────────────────────────────────────────

cmd_auth() {
    echo ""
    echo "  ${BOLD}🔑 bz — Authentication${NC}"
    echo ""

    local runtimes=("claude" "codex")

    for rt in "${runtimes[@]}"; do
        local cli_name="$rt"
        local status_icon status_text

        if ! command -v "$cli_name" >/dev/null 2>&1; then
            status_icon="${RED}✗${NC}"
            status_text="not installed"
            printf "  ${status_icon} ${BOLD}%-10s${NC} ${status_text}\n" "$cli_name"

            case "$cli_name" in
                claude) echo "    Install: npm install -g @anthropic-ai/claude-code" ;;
                codex)  echo "    Install: npm install -g @openai/codex" ;;
            esac
            continue
        fi

        # Check if authenticated by trying a quick operation
        local authenticated=0
        case "$cli_name" in
            claude)
                if claude --version >/dev/null 2>&1; then
                    # Claude stores auth in ~/.claude/
                    if [[ -d "$HOME/.claude" ]]; then
                        authenticated=1
                    fi
                fi
                ;;
            codex)
                if codex --version >/dev/null 2>&1; then
                    # Codex stores auth in ~/.codex/
                    if [[ -d "$HOME/.codex" ]] && ls "$HOME/.codex/auth"* >/dev/null 2>&1; then
                        authenticated=1
                    else
                        # Check if openai key exists in environment
                        [[ -n "${OPENAI_API_KEY:-}" ]] && authenticated=1
                    fi
                fi
                ;;
        esac

        if [[ "$authenticated" -eq 1 ]]; then
            status_icon="${GREEN}✓${NC}"
            status_text="authenticated"
            printf "  ${status_icon} ${BOLD}%-10s${NC} ${status_text}\n" "$cli_name"
        else
            status_icon="${YELLOW}!${NC}"
            status_text="installed but not authenticated"
            printf "  ${status_icon} ${BOLD}%-10s${NC} ${status_text}\n" "$cli_name"

            printf "    Authenticate now? [Y/n]: "
            read -r answer
            if [[ ! "$answer" =~ ^[Nn] ]]; then
                echo ""
                info "Launching ${cli_name} for authentication..."
                echo "    (Complete the login, then exit with Ctrl-C or type /exit)"
                echo ""
                $cli_name
                echo ""
                ok "${cli_name} authentication complete"
            fi
        fi
    done

    echo ""
}

# Helper: read a field for a specific agent by id
read_yaml_agent_field() {
    local target_id="$1"
    local field="$2"
    python3 -c "
import yaml
with open('bz.yaml') as f:
    data = yaml.safe_load(f)
for a in data.get('agents', []):
    if a.get('id') == '${target_id}':
        print(a.get('${field}', ''))
        break
" 2>/dev/null
}

