case "${1:-}" in
    new)       shift; cmd_new "$@" ;;
    auth)      shift; cmd_auth "$@" ;;
    launch)    shift; cmd_launch "$@" ;;
    status)    shift; cmd_status "$@" ;;
    attach)    shift; cmd_attach "$@" ;;
    logs)      shift; cmd_logs "$@" ;;
    feedback)  shift; cmd_feedback "$@" ;;
    teardown)  shift; cmd_teardown "$@" ;;
