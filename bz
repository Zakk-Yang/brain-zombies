#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BZ_DIR=".bz"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()  { printf "${BLUE}[i]${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}[✓]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[!]${NC} %s\n" "$*"; }
err()   { printf "${RED}[✗]${NC} %s\n" "$*" >&2; }

usage() {
    cat <<EOF
${BOLD}bz${NC} v${VERSION} — Brain for your coding agents

Usage: bz <command> [options]

Commands:
  new              Create a new project from a brief
  auth             Check & setup CLI authentication
  launch           Spawn all agents and supervisor
  status           Show agent states
  dashboard        Open monitoring dashboard
  feedback         Send human feedback to a zombie
  logs <agent>     Tail agent output
  attach <agent>   Attach to agent tmux session
  iterate          Autonomous improvement loop (brain→zombie→runner→evaluate)
  teardown         Stop all agents gracefully
  clean            Full purge (kill + delete state)

Options:
  -h, --help       Show this help
  -v, --version    Show version

Examples:
  bz new --brief PROJECT_BRIEF.md
  bz launch
  bz status
  bz attach developer
  bz teardown

  bz iterate --goal "ic > 0.10" --runner "./run.sh" --scope "train.py" --budget 10
EOF
}

# ── ITERATE ─────────────────────────────────────
cmd_iterate() {
    python3 "${SCRIPT_DIR}/lib/iterate.py" "$@"
}

# ── Helpers ──────────────────────────────────────

require_config() {
    if [[ ! -f "bz.yaml" ]]; then
        err "No bz.yaml found. Run 'bz new' first."
        exit 1
    fi
}

read_yaml() {
    python3 -c "
import yaml, sys
with open('bz.yaml') as f:
    data = yaml.safe_load(f)
path = sys.argv[1].split('.')
val = data
for p in path:
    if isinstance(val, list):
        val = val[int(p)]
    else:
        val = val.get(p, '')
print(val if val is not None else '')
" "$1" 2>/dev/null
}

read_yaml_list() {
    python3 -c "
import yaml
with open('bz.yaml') as f:
    data = yaml.safe_load(f)
agents = data.get('agents', [])
for a in agents:
    print(a.get('id', ''))
" 2>/dev/null
}

project_name() {
    read_yaml "project.name"
}

session_name() {
    echo "bz-$(project_name)-$1"
}

shell_quote() {
    printf '%q' "$1"
}

parse_blocked_until_dependencies() {
    local text="$1"
    [[ -n "$text" ]] || return 0

    text="$(printf '%s' "$text" | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//')"
    text="$(printf '%s' "$text" | sed -E 's/[[:space:]]+sets?[[:space:]]+State:[[:space:]]*done$//I')"
    text="$(printf '%s' "$text" | sed -E 's/[[:space:]]+and[[:space:]]+/, /Ig')"

    printf '%s\n' "$text" \
        | tr ',' '\n' \
        | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//' \
        | sed '/^$/Id; /^none$/Id'
}

join_csv_lines() {
    awk '
        NF {
            if (seen) {
                printf ", "
            }
            printf "%s", $0
            seen = 1
        }
    '
}

kill_tmux_session_tree() {
    local sess="$1"

    for pane_pid in $(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null); do
        pkill -TERM -P "$pane_pid" 2>/dev/null || true
        for child in $(pgrep -P "$pane_pid" 2>/dev/null); do
            pkill -TERM -P "$child" 2>/dev/null || true
        done
    done

    tmux kill-session -t "$sess" 2>/dev/null || true
}

wait_dashboard_ready() {
    local url="$1"

    if ! command -v curl >/dev/null 2>&1; then
        return 0
    fi

    for _ in {1..60}; do
        if curl -fsS --max-time 1 "${url}/api/health" >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.25
    done

    return 1
}

open_dashboard_url() {
    local url="$1"

    if [[ "${BZ_NO_OPEN:-0}" == "1" || "${CI:-}" == "true" ]]; then
        return 1
    fi

    if command -v wslview >/dev/null 2>&1; then
        (wslview "$url" >/dev/null 2>&1 &)
        return 0
    fi
    if command -v xdg-open >/dev/null 2>&1; then
        (xdg-open "$url" >/dev/null 2>&1 &)
        return 0
    fi
    if command -v open >/dev/null 2>&1; then
        (open "$url" >/dev/null 2>&1 &)
        return 0
    fi
    if command -v gio >/dev/null 2>&1; then
        (gio open "$url" >/dev/null 2>&1 &)
        return 0
    fi
    if command -v cmd.exe >/dev/null 2>&1; then
        (cmd.exe /C start "" "$url" >/dev/null 2>&1 &)
        return 0
    fi

    return 1
}

start_reconcile_loop() {
    local project_root_abs="$1"
    local reconcile_pid_file="${BZ_DIR}/reconcile.pid"
    local reconcile_log_file="${BZ_DIR}/logs/reconcile.log"
    local reconcile_session
    reconcile_session="$(session_name "nerve")"

    mkdir -p "${BZ_DIR}/logs"
    if [[ -f "$reconcile_pid_file" ]]; then
        kill "$(cat "$reconcile_pid_file")" 2>/dev/null || true
        rm -f "$reconcile_pid_file"
    fi
    kill_tmux_session_tree "$reconcile_session"

    local cmd
    cmd="cd $(shell_quote "$project_root_abs") && echo \$\$ > $(shell_quote "$reconcile_pid_file") && exec bash $(shell_quote "${SCRIPT_DIR}/lib/reconcile.sh") $(shell_quote "$project_root_abs") >> $(shell_quote "$reconcile_log_file") 2>&1"
    tmux new-session -d -s "$reconcile_session" -x 160 -y 40 "$cmd"
    ok "Reconcile loop started → tmux: ${reconcile_session}"
}

worktree_path() {
    echo "${BZ_DIR}/worktrees/$1"
}

control_plane() {
    python3 "${SCRIPT_DIR}/lib/control_plane.py" --project-root "$(pwd -P)" "$@"
}

install_bzctl_wrapper() {
    local wrapper_dir="$1"
    local project_root_abs="$2"
    local control_plane_py
    control_plane_py="$(realpath "${SCRIPT_DIR}/lib/control_plane.py")"

    mkdir -p "$wrapper_dir"
    cat > "${wrapper_dir}/bzctl" << EOF
#!/usr/bin/env bash
set -euo pipefail
python3 '${control_plane_py}' --project-root '${project_root_abs}' "\$@"
EOF
    chmod +x "${wrapper_dir}/bzctl"
}

agent_memory_relpath() {
    echo "${BZ_DIR}/project/memories/$1_mem.md"
}

brain_memory_relpath() {
    echo "${BZ_DIR}/project/memories/brain_mem.md"
}

shared_memory_relpath() {
    echo "${BZ_DIR}/project/memories/shared_mem.md"
}

agent_soul_relpath() {
    echo "${BZ_DIR}/project/souls/$1_soul.md"
}

brain_soul_relpath() {
    echo "${BZ_DIR}/project/souls/brain_soul.md"
}

agent_plan_relpath() {
    echo "${BZ_DIR}/project/plans/$1_plan.md"
}

project_doc_relpath() {
    echo "${BZ_DIR}/project/PROJECT.md"
}

target_doc_relpath() {
    echo "${BZ_DIR}/project/TARGET.md"
}

status_field() {
    local status_file="$1"
    local key="$2"
    grep "^${key}:" "$status_file" 2>/dev/null | head -1 | sed "s/^${key}: //"
}

write_status_file() {
    local path="$1"; shift
    local agent_id="$1"; shift
    local state="$1"; shift
    local action="$1"; shift
    local summary="$1"; shift
    local files_touched="$1"; shift
    local depends_on="$1"; shift
    local needs_brain="$1"; shift
    local next_step="$1"; shift
    local blocker="$1"; shift
    local memory_path="${1:-$(agent_memory_relpath "$agent_id")}"

    cat > "$path" <<EOF
# STATUS.md
State: ${state}
Action: ${action}
Summary: ${summary}
Files touched: ${files_touched}
Depends on: ${depends_on}
Needs brain: ${needs_brain}
Next step: ${next_step}
Blocker: ${blocker}
Memory: ${memory_path}
Last updated: $(date '+%Y-%m-%d %H:%M')
EOF
}

write_agent_memory_file() {
    local path="$1"
    local agent_id="$2"
    [[ -f "$path" ]] && return 0

    cat > "$path" <<EOF
# Agent Memory: ${agent_id}

## Current focus
- Waiting to begin.

## Important context
- Keep this file concise. Capture only decisions, discoveries, blockers, and handoff notes.

## Open items
- none

## Handoff for brain
- none
EOF
}

write_brain_memory_file() {
    local path="$1"
    [[ -f "$path" ]] && return 0

    cat > "$path" <<'EOF'
# Brain Memory

## Coordination notes
- Track cross-agent dependencies, review outcomes, and recurring failure modes here.

## Global blockers
- none

## Open handoffs
- none
EOF
}

sync_agent_protocol_to_worktree() {
    local agent_id="$1"
    local wt_path
    wt_path="$(worktree_path "$agent_id")"
    [[ -d "$wt_path" ]] || return 0

    mkdir -p \
        "${wt_path}/${BZ_DIR}/agents/${agent_id}" \
        "${wt_path}/${BZ_DIR}/memory/agents" \
        "${wt_path}/${BZ_DIR}/project/souls" \
        "${wt_path}/${BZ_DIR}/project/memories" \
        "${wt_path}/${BZ_DIR}/project/plans" \
        "${wt_path}/${BZ_DIR}/project/outputs/brain" \
        "${wt_path}/${BZ_DIR}/project/outputs/${agent_id}" \
        "${wt_path}/${BZ_DIR}/project/chatlogs" \
        "${wt_path}/${BZ_DIR}/project/scheduler" \
        "${wt_path}/${BZ_DIR}/control/agents/${agent_id}" \
        "${wt_path}/${BZ_DIR}/control/contexts" \
        "${wt_path}/${BZ_DIR}/bin"

    local rel_memory
    rel_memory="$(agent_memory_relpath "$agent_id")"

    [[ -f "${BZ_DIR}/agents/${agent_id}/BRIEF.md" ]] && cp "${BZ_DIR}/agents/${agent_id}/BRIEF.md" "${wt_path}/${BZ_DIR}/agents/${agent_id}/BRIEF.md"
    [[ -f "${BZ_DIR}/agents/${agent_id}/STATUS.md" ]] && cp "${BZ_DIR}/agents/${agent_id}/STATUS.md" "${wt_path}/${BZ_DIR}/agents/${agent_id}/STATUS.md"
    [[ -f "${BZ_DIR}/agents/${agent_id}/DECISION.md" ]] && cp "${BZ_DIR}/agents/${agent_id}/DECISION.md" "${wt_path}/${BZ_DIR}/agents/${agent_id}/DECISION.md"
    [[ -f "$(project_doc_relpath)" ]] && cp "$(project_doc_relpath)" "${wt_path}/$(project_doc_relpath)"
    [[ -f "$(target_doc_relpath)" ]] && cp "$(target_doc_relpath)" "${wt_path}/$(target_doc_relpath)"
    [[ -f "$(brain_soul_relpath)" ]] && cp "$(brain_soul_relpath)" "${wt_path}/$(brain_soul_relpath)"
    [[ -f "$(agent_soul_relpath "$agent_id")" ]] && cp "$(agent_soul_relpath "$agent_id")" "${wt_path}/$(agent_soul_relpath "$agent_id")"
    [[ -f "$(brain_memory_relpath)" ]] && cp "$(brain_memory_relpath)" "${wt_path}/$(brain_memory_relpath)"
    [[ -f "$(shared_memory_relpath)" ]] && cp "$(shared_memory_relpath)" "${wt_path}/$(shared_memory_relpath)"
    [[ -f "${rel_memory}" ]] && cp "${rel_memory}" "${wt_path}/${rel_memory}"
    [[ -f "$(agent_plan_relpath "$agent_id")" ]] && cp "$(agent_plan_relpath "$agent_id")" "${wt_path}/$(agent_plan_relpath "$agent_id")"
    [[ -f "${BZ_DIR}/project/scheduler/policy.yaml" ]] && cp "${BZ_DIR}/project/scheduler/policy.yaml" "${wt_path}/${BZ_DIR}/project/scheduler/policy.yaml"
    [[ -f "${BZ_DIR}/control/contexts/${agent_id}.md" ]] && cp "${BZ_DIR}/control/contexts/${agent_id}.md" "${wt_path}/${BZ_DIR}/control/contexts/${agent_id}.md"
    [[ -f "${BZ_DIR}/control/agents/${agent_id}/latest-action.md" ]] && cp "${BZ_DIR}/control/agents/${agent_id}/latest-action.md" "${wt_path}/${BZ_DIR}/control/agents/${agent_id}/latest-action.md"
    [[ -f "${BZ_DIR}/bin/bzctl" ]] && cp "${BZ_DIR}/bin/bzctl" "${wt_path}/${BZ_DIR}/bin/bzctl"
}

# ── NEW ──────────────────────────────────────────

cmd_new() {
    local brief_file=""
    local auto_yes=0
    local auto_dashboard=1

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --brief|-b) brief_file="$2"; shift 2 ;;
            -y) auto_yes=1; shift ;;
            --dashboard) auto_dashboard=1; shift ;;
            --no-dashboard) auto_dashboard=0; shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    if [[ -f "bz.yaml" ]]; then
        warn "bz.yaml already exists. Overwrite? [y/N]"
        read -r answer
        [[ "$answer" =~ ^[Yy] ]] || exit 0
    fi

    echo ""
    echo "  ${BOLD}🧠 bz — New Project${NC}"
    echo ""

    # Read brief
    local brief=""
    if [[ -n "$brief_file" && -f "$brief_file" ]]; then
        brief="$(cat "$brief_file")"
        info "Read brief from $brief_file"
    else
        echo "Paste your project brief (end with Ctrl-D):"
        brief="$(cat)"
    fi

    if [[ -z "$brief" ]]; then
        err "Empty brief. Provide a project description."
        exit 1
    fi

    # Ask runtime preferences
    local runtime="claude"
    local model_tier="balanced"
    local git_strategy="worktree"

    if [[ "$auto_yes" -eq 0 ]]; then
        echo ""
        printf "Coding CLI? [${BOLD}claude${NC} / codex / aider]: "
        read -r answer
        [[ -n "$answer" ]] && runtime="$answer"

        printf "Model tier? [budget / ${BOLD}balanced${NC} / quality]: "
        read -r answer
        [[ -n "$answer" ]] && model_tier="$answer"

        printf "Git strategy? [${BOLD}worktree${NC} / shared]: "
        read -r answer
        [[ -n "$answer" ]] && git_strategy="$answer"
    fi

    # Map runtime to CLI command
    local cli_cmd
    case "$runtime" in
        claude|claude-code) cli_cmd="claude" ;;
        codex) cli_cmd="codex" ;;
        aider) cli_cmd="aider" ;;
        *) cli_cmd="$runtime" ;;
    esac

    # Map model tier to model names
    local supervisor_model agent_model
    case "$cli_cmd" in
        claude)
            case "$model_tier" in
                budget)   supervisor_model="haiku"; agent_model="haiku" ;;
                balanced) supervisor_model="sonnet"; agent_model="sonnet" ;;
                quality)  supervisor_model="opus"; agent_model="opus" ;;
            esac
            ;;
        codex)
            case "$model_tier" in
                budget)   supervisor_model="gpt-4.1-mini"; agent_model="gpt-4.1-mini" ;;
                balanced) supervisor_model="gpt-4.1"; agent_model="gpt-4.1" ;;
                quality)  supervisor_model="gpt-5.4"; agent_model="gpt-5.4" ;;
            esac
            ;;
        *)
            supervisor_model=""; agent_model=""
            ;;
    esac

    info "Generating project config with ${cli_cmd}..."

    # Use the supervisor CLI to analyze the brief and generate config
    source "${SCRIPT_DIR}/lib/planner.sh"
    generate_config "$brief" "$cli_cmd" "$supervisor_model" "$agent_model" "$git_strategy"

    ok "Generated bz.yaml"
    local init_args=(--project-root "$(pwd -P)")
    [[ "$auto_yes" -eq 1 ]] && init_args+=(--yes)
    python3 "${SCRIPT_DIR}/lib/project_init.py" "${init_args[@]}"
    ok "Initialized ${BZ_DIR}/project"
    echo ""
    cat bz.yaml
    echo ""

    local launched=0
    if [[ "$auto_yes" -eq 0 ]]; then
        printf "Launch now? [Y/n]: "
        read -r answer
        if [[ ! "$answer" =~ ^[Nn] ]]; then
            launched=1
            cmd_launch
        fi
    fi

    if [[ "$auto_dashboard" -eq 1 && "$launched" -eq 0 ]]; then
        cmd_dashboard
    fi
}

# ── LAUNCH ───────────────────────────────────────

cmd_launch() {
    local auto_dashboard=1

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-dashboard) auto_dashboard=0; shift ;;
            --dashboard) auto_dashboard=1; shift ;;
            *) err "Unknown launch option: $1"; exit 1 ;;
        esac
    done

    require_config
    local project
    project="$(project_name)"
    local project_root_abs
    project_root_abs="$(pwd -P)"
    python3 "${SCRIPT_DIR}/lib/project_init.py" --project-root "${project_root_abs}" --yes --no-config-write >/dev/null

    echo ""
    echo "  ${BOLD}🚀 bz — Launch${NC}"
    echo "  Project: ${project}"
    echo ""

    mkdir -p "${BZ_DIR}/agents" "${BZ_DIR}/logs" "${BZ_DIR}/memory/agents" "${BZ_DIR}/project/memories"
    write_brain_memory_file "$(brain_memory_relpath)"

    # Preflight: check required CLIs are installed and authenticated
    local required_runtimes=()
    local -A checked_runtimes=()
    for _idx in $(python3 -c "
import yaml
with open('bz.yaml') as f:
    d = yaml.safe_load(f)
for i, a in enumerate(d.get('agents', [])):
    print(a.get('runtime', 'claude'))
" < /dev/null 2>/dev/null); do
        required_runtimes+=("$_idx")
    done

    for rt in "${required_runtimes[@]}"; do
        [[ -n "${checked_runtimes[$rt]:-}" ]] && continue
        checked_runtimes[$rt]=1

        local cli_name
        case "$rt" in
            claude|claude-code) cli_name="claude" ;;
            codex) cli_name="codex" ;;
            *) cli_name="$rt" ;;
        esac

        if ! command -v "$cli_name" >/dev/null 2>&1; then
            err "${cli_name} is not installed. Install it first:"
            case "$cli_name" in
                claude) echo "  npm install -g @anthropic-ai/claude-code" ;;
                codex)  echo "  npm install -g @openai/codex" ;;
                *)      echo "  Install ${cli_name} and ensure it's in PATH" ;;
            esac
            exit 1
        fi

        # Quick auth check
        local auth_ok=0
        case "$cli_name" in
            claude)
                if claude --version >/dev/null 2>&1; then auth_ok=1; fi
                ;;
            codex)
                if codex --version >/dev/null 2>&1; then auth_ok=1; fi
                ;;
            *)
                auth_ok=1  # assume ok for unknown CLIs
                ;;
        esac

        if [[ "$auth_ok" -eq 0 ]]; then
            warn "${cli_name} is installed but may not be authenticated."
            printf "  Authenticate now? [Y/n]: "
            read -r auth_answer
            if [[ ! "$auth_answer" =~ ^[Nn] ]]; then
                info "Launching ${cli_name} for authentication..."
                echo "  (Complete the login, then exit with Ctrl-C or type /exit)"
                $cli_name
                ok "${cli_name} authentication complete"
            else
                err "Cannot launch without authentication."
                exit 1
            fi
        fi

        ok "${cli_name} ready"
    done

    # Initialize git if needed
    if [[ ! -d ".git" ]]; then
        git init -q
        git add -A
        git commit -q -m "Initial commit"
        ok "Git initialized"
    fi

    local git_strategy
    git_strategy="$(read_yaml 'git.strategy')"

    # Spawn each agent
    local -a agent_ids=()
    while IFS= read -r _aid; do
        [[ -n "$_aid" ]] && agent_ids+=("$_aid")
    done <<< "$(read_yaml_list)"
    local agent_index=0

    control_plane init --agents "${agent_ids[@]}" supervisor >/dev/null 2>&1 || true
    install_bzctl_wrapper "${BZ_DIR}/bin" "${project_root_abs}"

    for agent_id in "${agent_ids[@]}"; do

        local runtime cli_cmd model task focus blocked_until thinking max_iterations
        runtime="$(read_yaml "agents.${agent_index}.runtime" < /dev/null)"
        model="$(read_yaml "agents.${agent_index}.model" < /dev/null)"
        task="$(read_yaml "agents.${agent_index}.task" < /dev/null)"
        focus="$(read_yaml "agents.${agent_index}.focus" < /dev/null)"
        blocked_until="$(read_yaml "agents.${agent_index}.blocked_until" < /dev/null)"
        thinking="$(read_yaml "agents.${agent_index}.thinking" < /dev/null)"
        max_iterations="$(read_yaml "agents.${agent_index}.max_iterations" < /dev/null)"
        [[ -z "$max_iterations" || "$max_iterations" == "None" ]] && max_iterations="$(read_yaml "supervisor.max_agent_iterations" < /dev/null)"
        [[ -z "$max_iterations" || "$max_iterations" == "None" ]] && max_iterations="5"

        case "$runtime" in
            claude|claude-code) cli_cmd="claude" ;;
            codex) cli_cmd="codex" ;;
            *) cli_cmd="$runtime" ;;
        esac

        # Create agent dir
        local agent_dir="${BZ_DIR}/agents/${agent_id}"
        mkdir -p "${agent_dir}"
        local memory_rel
        memory_rel="$(agent_memory_relpath "$agent_id")"
        write_agent_memory_file "${memory_rel}" "${agent_id}"

        # Write BRIEF.md
        cat > "${agent_dir}/BRIEF.md" << BRIEFEOF
# Agent: ${agent_id}

## Project Context
- Project: $(project_doc_relpath)
- Target criteria: $(target_doc_relpath)
- Your soul: $(agent_soul_relpath "$agent_id")
- Brain soul: $(brain_soul_relpath)
- Shared memory: $(shared_memory_relpath)
- Your memory: ${memory_rel}
- Your plan: $(agent_plan_relpath "$agent_id")
- Your output directory: ${BZ_DIR}/project/outputs/${agent_id}/

## Task
${task}

## Focus directories
${focus}

## Memory
- Your private memory: ${memory_rel}
- Shared memory: $(shared_memory_relpath)
- Brain memory: $(brain_memory_relpath) (read only when needed)

## Rules
- After EACH file you create/modify: git add <file> && git commit -m "[${agent_id}] <description>"
- Before implementation: write a concrete step-by-step plan to $(agent_plan_relpath "$agent_id")
- After each meaningful step: update the canonical control plane with .bz/bin/bzctl write-state --agent ${agent_id} ...
- For every task/subtask boundary, append a DB task event with .bz/bin/bzctl task-event --agent ${agent_id} --task "..." --sub-task "..." --state <start|working|end|hold|blocked|review|done> --notes "..."
- While active, update state at least every 10 minutes even if no output is ready yet
- STATUS.md is compatibility output. If bzctl is unavailable, update ${BZ_DIR}/agents/${agent_id}/STATUS.md using the exact field names already present
- Read .bz/control/contexts/${agent_id}.md before new work and whenever a new action arrives
- Keep ${memory_rel} current with concise bullets for decisions, blockers, and handoff context
- Record durable facts/handoffs in the control plane with .bz/bin/bzctl add-memory --owner agent:${agent_id} ...
- When you need supervisor help, set Needs brain: review|unblock|redirect and explain why in Blocker/Next step
- Set State: ready-for-review and Needs brain: review when you believe your task is complete
- Your automatic review-attempt budget is ${max_iterations} ready-for-review submissions; if exhausted, stop and wait for human budget extension
$([ -n "$blocked_until" ] && echo "- You are BLOCKED until: ${blocked_until}. Set State: blocked until the condition is met.")
BRIEFEOF

        # Write initial STATUS.md
        local dependency_hint="none"
        if [[ -n "$blocked_until" ]]; then
            dependency_hint="$(parse_blocked_until_dependencies "$blocked_until" | join_csv_lines)"
            [[ -z "$dependency_hint" ]] && dependency_hint="none"
        fi
        local initial_state="starting"
        local initial_action="reading brief"
        local initial_needs_brain="no"
        local initial_next_step="Read BRIEF.md and begin task."
        if [[ -n "$blocked_until" ]]; then
            initial_state="blocked"
            initial_action="waiting on dependency"
            initial_needs_brain="no"
            initial_next_step="Wait for dependency or supervisor unblock."
        fi
        write_status_file \
            "${agent_dir}/STATUS.md" \
            "${agent_id}" \
            "${initial_state}" \
            "${initial_action}" \
            "Not started yet." \
            "none" \
            "${dependency_hint}" \
            "${initial_needs_brain}" \
            "${initial_next_step}" \
            "${blocked_until:-none}" \
            "${memory_rel}"

        # Create worktree if needed
        local work_dir="."
        if [[ "$git_strategy" == "worktree" ]]; then
            local wt_path
            wt_path="$(worktree_path "$agent_id")"
            local branch="bz/${agent_id}"

            if [[ -d "$wt_path" ]]; then
                git worktree remove "$wt_path" --force 2>/dev/null || true
            fi
            git branch -D "$branch" 2>/dev/null || true
            git worktree add -q "$wt_path" -b "$branch" 2>/dev/null || true
            # Copy agent state to worktree
            mkdir -p "${wt_path}/${BZ_DIR}/agents/${agent_id}"
            mkdir -p "${wt_path}/${BZ_DIR}/memory/agents"
            mkdir -p "${wt_path}/${BZ_DIR}/project/souls" "${wt_path}/${BZ_DIR}/project/memories" "${wt_path}/${BZ_DIR}/project/plans" "${wt_path}/${BZ_DIR}/project/outputs/brain" "${wt_path}/${BZ_DIR}/project/outputs/${agent_id}" "${wt_path}/${BZ_DIR}/project/chatlogs" "${wt_path}/${BZ_DIR}/project/scheduler"
            cp "${agent_dir}/BRIEF.md" "${wt_path}/${BZ_DIR}/agents/${agent_id}/"
            cp "${agent_dir}/STATUS.md" "${wt_path}/${BZ_DIR}/agents/${agent_id}/"
            [[ -f "$(project_doc_relpath)" ]] && cp "$(project_doc_relpath)" "${wt_path}/$(project_doc_relpath)"
            [[ -f "$(target_doc_relpath)" ]] && cp "$(target_doc_relpath)" "${wt_path}/$(target_doc_relpath)"
            [[ -f "$(brain_soul_relpath)" ]] && cp "$(brain_soul_relpath)" "${wt_path}/$(brain_soul_relpath)"
            [[ -f "$(agent_soul_relpath "$agent_id")" ]] && cp "$(agent_soul_relpath "$agent_id")" "${wt_path}/$(agent_soul_relpath "$agent_id")"
            [[ -f "$(brain_memory_relpath)" ]] && cp "$(brain_memory_relpath)" "${wt_path}/$(brain_memory_relpath)"
            [[ -f "$(shared_memory_relpath)" ]] && cp "$(shared_memory_relpath)" "${wt_path}/$(shared_memory_relpath)"
            [[ -f "${memory_rel}" ]] && cp "${memory_rel}" "${wt_path}/${memory_rel}"
            [[ -f "$(agent_plan_relpath "$agent_id")" ]] && cp "$(agent_plan_relpath "$agent_id")" "${wt_path}/$(agent_plan_relpath "$agent_id")"
            [[ -f "${BZ_DIR}/project/scheduler/policy.yaml" ]] && cp "${BZ_DIR}/project/scheduler/policy.yaml" "${wt_path}/${BZ_DIR}/project/scheduler/policy.yaml"
            work_dir="$wt_path"
            ok "Created worktree: ${branch}"
        fi

        install_bzctl_wrapper "${work_dir}/${BZ_DIR}/bin" "${project_root_abs}"
        control_plane write-state \
            --agent "$agent_id" \
            --phase "${initial_state}" \
            --action "${initial_action}" \
            --summary "Not started yet." \
            --depends-on "${dependency_hint}" \
            --needs-brain "${initial_needs_brain}" \
            --files "" \
            --next-step "${initial_next_step}" \
            --blocker "${blocked_until:-none}" \
            --updated-by system \
            --source launch >/dev/null

        # Build agent prompt
        local prompt="You are an autonomous coding agent named '${agent_id}'. Execute your task NOW without asking questions.

Read ${BZ_DIR}/agents/${agent_id}/BRIEF.md for your task.
Read $(project_doc_relpath), $(target_doc_relpath), $(agent_soul_relpath "$agent_id"), $(shared_memory_relpath), and ${memory_rel}.
Read .bz/control/contexts/${agent_id}.md before touching code.
Write your implementation plan to $(agent_plan_relpath "$agent_id") before changing project files.

CRITICAL RULES:
1. After EACH file: git add <file> && git commit -m \"[${agent_id}] <description>\"
2. Canonical status/action lives in the control plane. After each meaningful step and every commit, run:
   .bz/bin/bzctl write-state --agent ${agent_id} --phase <starting|planning|blocked|working|executing|ready-for-review> --action \"<current action>\" --summary \"<one-line summary>\" --depends-on \"<agent-id|none>\" --needs-brain \"<no|review|unblock|redirect>\" --files \"file1,file2\" --next-step \"<next step>\" --blocker \"<none or blocker>\" --updated-by agent
3. For every task/subtask boundary, run:
   .bz/bin/bzctl task-event --agent ${agent_id} --task \"<task>\" --sub-task \"<subtask>\" --state <start|working|end|hold|blocked|review|done> --notes \"<short note>\" --source agent
4. While active, update state at least every 10 minutes even if you have no new output yet
5. Keep ${memory_rel} concise and current with decisions, blockers, and handoff notes
6. Record durable context in the control plane:
   .bz/bin/bzctl add-memory --owner agent:${agent_id} --scope <private|shared> --kind <observation|decision|handoff|result|constraint> --summary \"<one-line memory>\" --details \"<durable details only>\"
7. State lifecycle: starting → planning → blocked → working → executing → ready-for-review → done
   - Set State: working while writing code
   - Set Action: <current concrete verb phrase> at all times
   - Set State: executing when running scripts/experiments (no more code changes, just compute)
   - Set Depends on: <agent-id> when you are waiting on another zombie, otherwise none
   - Set Needs brain: unblock if blocked, redirect if you need new instructions, review when finished, otherwise no
   - Set State: ready-for-review when you believe your task is complete (brain will confirm)
   - Only the brain sets State: done after reviewing your work
   - Your automatic review-attempt budget is ${max_iterations}; if the control plane reports budget exhausted, stop and wait for human budget extension
8. If a brain or human message arrives, immediately re-read .bz/control/contexts/${agent_id}.md and .bz/control/agents/${agent_id}/latest-action.md before acting

CONTEXT MANAGEMENT — keep your memory lean:
- Do NOT read files you don't need. Only read files relevant to your current step.
- Do NOT re-read files you already read. Remember what's in them.
- Do NOT cat large files — use grep or head to find what you need.
- Write files in one shot — don't read-modify-write when you can just write.
- Keep status and memory updates short — one-line summaries and bullets, not paragraphs.
- If you receive a brain message, act on it immediately without re-reading everything.

START NOW."

        # Write prompt to file to avoid shell escaping issues
        local prompt_file="${agent_dir}/PROMPT.txt"
        echo "$prompt" > "$prompt_file"
        # Also copy to worktree if using worktrees
        if [[ "$git_strategy" == "worktree" ]]; then
            cp "$prompt_file" "${work_dir}/${BZ_DIR}/agents/${agent_id}/PROMPT.txt" 2>/dev/null || true
        fi

        # Spawn tmux session (kill existing + child processes first)
        local sess
        sess="$(session_name "$agent_id")"
        for pane_pid in $(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null); do
            pkill -TERM -P "$pane_pid" 2>/dev/null || true
            for child in $(pgrep -P "$pane_pid" 2>/dev/null); do
                pkill -TERM -P "$child" 2>/dev/null || true
            done
        done
        tmux kill-session -t "$sess" 2>/dev/null || true

        local abs_work_dir
        abs_work_dir="$(realpath "$work_dir")"
        local abs_prompt_file="${abs_work_dir}/${BZ_DIR}/agents/${agent_id}/PROMPT.txt"
        [[ ! -f "$abs_prompt_file" ]] && abs_prompt_file="$(realpath "$prompt_file")"

        local cmd
        if [[ "$cli_cmd" == "claude" ]]; then
            cmd="cd $(shell_quote "$abs_work_dir") && claude --dangerously-skip-permissions"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            # Claude Code CLI uses --effort (low/medium/high/max), not --thinking
            if [[ -n "$thinking" && "$thinking" != "None" && "$thinking" != "off" ]]; then
                if [[ "$thinking" == "disabled" || "$thinking" == "off" ]]; then
                    cmd="$cmd --effort low"
                elif [[ "$thinking" == "max" || "$thinking" == "xhigh" ]]; then
                    cmd="$cmd --effort max"
                elif [[ "$thinking" == "high" || "$thinking" == "enabled" ]]; then
                    cmd="$cmd --effort high"
                elif [[ "$thinking" == "medium" ]]; then
                    cmd="$cmd --effort medium"
                fi
            fi
            cmd="$cmd -p \"\$(cat ${abs_prompt_file})\""
        elif [[ "$cli_cmd" == "codex" ]]; then
            cmd="cd $(shell_quote "$abs_work_dir") && codex exec --full-auto --add-dir $(shell_quote "$project_root_abs")"
            [[ -n "$model" ]] && cmd="$cmd --model $model"
            cmd="$cmd \"\$(cat ${abs_prompt_file})\""
        else
            cmd="cd $(shell_quote "$abs_work_dir") && ${cli_cmd} \"\$(cat ${abs_prompt_file})\""
        fi

        tmux new-session -d -s "$sess" -x 200 -y 50
        tmux send-keys -t "$sess" "$cmd" Enter
        ok "Spawned ${agent_id} (${cli_cmd}/${model}) → tmux: ${sess}"

        agent_index=$((agent_index + 1))
    done

    # Brain runs on-demand (spawned by reconcile loop when needed)
    local sup_dir="${BZ_DIR}/agents/supervisor"
    mkdir -p "$sup_dir"
    write_status_file \
        "${sup_dir}/STATUS.md" \
        "supervisor" \
        "monitoring" \
        "watching agent protocol" \
        "Brain ready. Wakes on-demand when nerve detects state changes." \
        "none" \
        "all-agents" \
        "no" \
        "Wait for nerve signals." \
        "none" \
        "$(brain_memory_relpath)"
    control_plane write-state \
        --agent supervisor \
        --phase monitoring \
        --action "watching control-plane state" \
        --summary "Brain ready. Wakes on-demand with structured context." \
        --depends-on all-agents \
        --needs-brain no \
        --files "" \
        --next-step "Wait for nerve signals." \
        --blocker none \
        --updated-by system \
        --source launch >/dev/null
    ok "Brain ready (on-demand, wakes on state changes)"

    # Start reconcile loop in tmux so it survives the launcher shell exiting.
    start_reconcile_loop "${project_root_abs}"

    echo ""
    echo "  ${GREEN}${BOLD}Agents launched!${NC}"
    echo ""

    if [[ "$auto_dashboard" -eq 1 ]]; then
        cmd_dashboard
    fi

    echo ""
    echo "  ${BOLD}Commands:${NC}"
    echo "    bz status          Show agent states"
    echo "    bz dashboard       Open monitoring dashboard"
    echo "    bz feedback        Send human feedback"
    echo "    bz attach <agent>  Attach to agent session"
    echo "    bz teardown        Stop everything"
    echo ""
}

# ── STATUS ───────────────────────────────────────

cmd_status() {
    require_config
    local project
    project="$(project_name)"

    echo ""
    echo "  ${BOLD}🧠 bz — ${project}${NC}"
    echo ""

    if [[ ! -d "${BZ_DIR}/agents" ]]; then
        warn "No agents found. Run 'bz launch' first."
        return
    fi

    control_plane sync-all --quiet >/dev/null 2>&1 || true

    printf "  ${BOLD}%-16s %-10s %-20s %-8s %-34s${NC}\n" "Agent" "State" "Action" "Ctx" "Summary"
    printf "  %-16s %-10s %-20s %-8s %-34s\n" "────────────────" "──────────" "────────────────────" "────────" "──────────────────────────────────"

    for agent_dir in "${BZ_DIR}/agents"/*/; do
        [[ -d "$agent_dir" ]] || continue
        local agent_id
        agent_id="$(basename "$agent_dir")"
        local status_file="${agent_dir}/STATUS.md"

        if [[ ! -f "$status_file" ]]; then
            printf "  %-16s %-10s %-20s %-8s %-34s\n" "$agent_id" "unknown" "-" "-" "No STATUS.md"
            continue
        fi

        local state action summary ctx_display
        state="$(status_field "$status_file" "State")"
        action="$(status_field "$status_file" "Action" | cut -c1-18)"
        summary="$(status_field "$status_file" "Summary" | cut -c1-32)"

        # Estimate context usage from tmux pane output
        local sess
        sess="$(session_name "$agent_id")"
        ctx_display="-"
        if tmux has-session -t "$sess" 2>/dev/null; then
            local pane_lines
            pane_lines="$(tmux capture-pane -t "$sess" -p -S - 2>/dev/null | wc -c)"
            local est_tokens=$((pane_lines / 4))  # rough: 4 chars ≈ 1 token
            if [[ "$est_tokens" -gt 100000 ]]; then
                ctx_display="${RED}$(( est_tokens / 1000 ))k${NC}"
            elif [[ "$est_tokens" -gt 50000 ]]; then
                ctx_display="${YELLOW}$(( est_tokens / 1000 ))k${NC}"
            else
                ctx_display="${GREEN}$(( est_tokens / 1000 ))k${NC}"
            fi
        fi

        local color="$NC"
        case "$state" in
            done) color="$GREEN" ;;
            working|planning|executing|monitoring) color="$BLUE" ;;
            ready-for-review) color="$GREEN" ;;
            blocked) color="$YELLOW" ;;
            *) color="$RED" ;;
        esac

        printf "  %-16s ${color}%-10s${NC} %-20s ${ctx_display}%-2s %-34s\n" "$agent_id" "$state" "${action:-"-"}" "" "$summary"
    done

    # Show tmux sessions
    echo ""
    local sessions
    sessions="$(tmux list-sessions 2>/dev/null | grep "bz-$(project_name)" || true)"
    if [[ -n "$sessions" ]]; then
        info "Active tmux sessions:"
        echo "$sessions" | while read -r line; do
            echo "    $line"
        done
    fi
    echo ""
}

